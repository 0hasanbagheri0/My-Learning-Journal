# %%
import pandas as pd  #فراخوانی کتابخانه پانداس 

# %%
s1 = pd.Series([1,3,5,None,9,11,13])  #تعریف سری جدید

# %%
s1.count()    #تعداد داده ها

# %%
s1.prod()    #ضرب داده ها

# %%
s1.sum()    #جمع داده ها

# %%
s1.cumsum()    # مجموع تجمعی داده ها

# %%
s1.cumsum(skipna=False)    #skipna اگر برابر falseباشد جمع و یا ضرب دیگر انجام نمیشود 

# %%
s1.pct_change()    #درصد تغییرات متغیرs1

# %%
s1.min(),s1.max(),s1.median(),s1.mean(),s1.std(),s1.var()    # چند شاخص مرکزی  

# %%
s1.describe()    #توصیف متغیر s1

# %%
s1.sample()    #یک نمونه از s1

# %%
for _ in range(5):    #دستوری برای  5 نمونه تصادفی ار متعیر s1
    print(s1.sample())

# %%
s1.sample(n=15 , replace=True)    #15 نمونه قابل جایگزاری از s1

