import pandas as pd   #وارد کردن کتابخانه پانداس

# %%
print('\n"نمایش 5 ردیف اول فیلمها"')
df=pd.read_csv('data\movies.csv',index_col='name')    #لود کردن فایل movies
df.head()

# %%
df['score']   #نمایش ستون نمره 

# %%
print('\n "نمایش نمره فیلمها"')
df.score #امکان نمایش ستون نمره به صورت روبرو و کد بالا


# %%
print('\n "بررسی کمتر از 9 یا بیشتر از 9 بودن نمره فیلم ها"')

df['score'] >= 9


# %%
print('\n "فیلمهای دارای امتیاز 9 و بیشتر"')
df[df['score'] >= 9]

# %%
High_Score_Movies = (df['score']>=8.8)  #تعریف متغیر جدید
print('\n "فیلمهای با نمره بیشتر از 8.8"')
df[High_Score_Movies]



# %%
cond1 =df['score']>=7 #شرط اول نمره فیلم بیشتر یا مساوی  7
cond2 =df['score']<=8 #شرط دوم نمره فیلم کمتر یا مساوی  8
print('\n"نمایش فیلمهای با نمره کمتر مساوی 8 و بیشتر مساوی 7"')
df[cond1 & cond2] 

# %%
High_Score_Movies =(df['score']>= 8.5)
After_2015 = (df['year']>=2015)
print('\n"فیلمها با امتیاز بیشتر از 8.5 که بعد از سال 2015 اکران شده اند:"')
df[High_Score_Movies&After_2015]
